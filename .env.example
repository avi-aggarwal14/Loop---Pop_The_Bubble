# ── Anthropic (Growth Brief engine) ───────────────────────────────
# Brief generation runs on Anthropic Claude. Server-only. Never expose to the client.
# Must be an Anthropic *API* key from console.anthropic.com (starts with sk-ant-...).
ANTHROPIC_API_KEY=
# Model the briefs are generated with. Defaults to the most capable Claude model.
ANTHROPIC_MODEL=claude-opus-4-8
# Effort controls thinking depth + token spend: low | medium | high | xhigh | max.
# Set to "none" to omit it entirely (falls back to the model default).
ANTHROPIC_EFFORT=high

# ── mubit (operational memory) ────────────────────────────────────
# Get the API key + confirm the base URL/auth from https://console.mubit.ai/app/overview
# Base URL and auth header are env-driven because the gated docs may differ from the
# public /v2/control/* shapes this client was written against.
MUBIT_API_KEY=
MUBIT_BASE_URL=https://api.mubit.ai
# How the key is sent. Common options: "bearer" (Authorization: Bearer <key>) or "x-api-key".
MUBIT_AUTH_SCHEME=bearer

# ── Supabase (Postgres, Auth, storage) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-only, used by ingestion/cron jobs. NEVER ship to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── App URL (used to build OAuth redirect URIs) ───────────────────
# Public base URL of the app. Falls back to SHOPIFY_APP_URL if unset.
APP_URL=http://localhost:3000

# ── Shopify (orders + ShopifyQL analytics) ────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# read_reports unlocks ShopifyQL sessions/conversion (plan-dependent).
SHOPIFY_SCOPES=read_orders,read_customers,read_products,read_reports
SHOPIFY_APP_URL=http://localhost:3000

# ── Google Analytics (GA4 Data API) ───────────────────────────────
# Google Cloud project → OAuth client (scope analytics.readonly).
# Redirect URI to register: <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override for the website business-profile extraction model.
# ANTHROPIC_EXTRACT_MODEL=claude-opus-4-8

# ── Vercel Web Analytics ──────────────────────────────────────────
# No global key. The founder configures a Vercel Drain pointing at:
#   <APP_URL>/api/ingest/vercel?cid=<connectionId>&secret=<drainSecret>
# The per-connection drain secret lives in connections.config.drain_secret.

# ── Cron (weekly brief job) ───────────────────────────────────────
# Protects /api/cron/generate-briefs. Vercel Cron sends this as a Bearer token.
# Generate any long random string.
CRON_SECRET=

# ── Waitlist (landing page email capture → Kit / ConvertKit) ──────
# Used by /api/waitlist. Server-only. Configure EITHER option (A is simplest):
#
# A) No API key needed. In your Kit form: Embed → HTML, copy the <form action="...">
#    URL (looks like https://app.kit.com/forms/1234567/subscriptions) and paste here:
KIT_FORM_ACTION=
#
# B) v3 API instead (Settings → Advanced → API → "API Key", + the number in the
#    form's edit URL as the Form ID):
KIT_API_KEY=
KIT_FORM_ID=
#
# If none are set, signups are logged and the form still returns success (so the
# demo never breaks) but nothing is stored. Turn ON double opt-in in the form's
# settings so every signup must confirm its own email.
